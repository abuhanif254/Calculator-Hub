rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mohammadbitullah@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    match /users/{userId} {
      // Anyone can read profiles
      allow read: if true; 
      // Users can create/update their own profiles. Admins can update any.
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      // Only admins can delete users
      allow delete: if isAdmin();
    }

    match /posts/{postId} {
      // Anyone can read posts
      allow read: if true; 
      
      // Signed in users can create posts
      allow create: if isSignedIn() 
                    && incoming().authorId == request.auth.uid;
                    
      // Authors can update their own posts. Admins can update any post.
      allow update: if (isSignedIn() && request.auth.uid == existing().authorId) || isAdmin();
                    
      // Authors can delete their own posts. Admins can delete any post.
      allow delete: if (isSignedIn() && request.auth.uid == existing().authorId) || isAdmin();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if (isSignedIn() && request.auth.uid == existing().authorId) || isAdmin();
      allow delete: if (isSignedIn() && request.auth.uid == existing().authorId) || isAdmin();
    }

    match /likes/{likeId} {
      // likeId should be structured as {postId}_{userId} or {commentId}_{userId}
      allow read: if true;
      allow create: if isSignedIn();
      allow delete: if isSignedIn();
    }

    match /playground_pens/{penId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
    }
  }
}

