rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net - blocks anything not explicitly allowed below
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions for security checks
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mohammadbitullah@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // 1. Users Collection
    match /users/{userId} {
      // Anyone can read profiles
      allow read: if true; 
      // Users can create/update their own profiles. Admins can update any.
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isSignedIn() && request.auth.uid == userId) || isAdmin();
      // Only admins can delete users
      allow delete: if isAdmin();

      // --- NEW SUBCOLLECTION RULES ---
      match /notifications/{notifId} {
        // Users can manage their own notifications
        allow read, update, delete: if isSignedIn() && request.auth.uid == userId;
        // Any signed in user can send a notification (e.g. when liking/commenting)
        allow create: if isSignedIn();
      }
      
      match /followers/{followerId} {
        allow read: if true;
        allow write: if isSignedIn(); // Anyone signed in can follow/unfollow
      }
      
      match /following/{followingId} {
        allow read: if true;
        // Users can only manage who *they* are following
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
      
      match /drafts/{draftId} {
        // Users can only access their own drafts
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 2. Posts Collection
    match /posts/{postId} {
      // Anyone can read posts
      allow read: if true; 
      // Signed in users can create posts
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      // Authors can update their own posts. Admins can update any post.
      allow update: if (isSignedIn() && request.auth.uid == existing().authorId) || isAdmin();
      // Authors can delete their own posts. Admins can delete any post.
      allow delete: if (isSignedIn() && request.auth.uid == existing().authorId) || isAdmin();
    }

    // 3. Comments Collection
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn() && incoming().authorId == request.auth.uid;
      allow update: if (isSignedIn() && request.auth.uid == existing().authorId) || isAdmin();
      allow delete: if (isSignedIn() && request.auth.uid == existing().authorId) || isAdmin();
    }

    // 4. Likes Collection
    match /likes/{likeId} {
      allow read: if true;
      allow create, delete: if isSignedIn();
    }

    // 5. Playground Pens (Preserving your existing rule)
    match /playground_pens/{penId} {
      allow read, create, update: if true;
    }
  }
}
