{
  "entities": {
    "User": {
      "title": "User",
      "description": "A community user",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A community post",
      "type": "object",
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "number", "description": "Timestamp" },
        "updatedAt": { "type": "number", "description": "Timestamp" }
      },
      "required": ["slug", "title", "content", "authorId", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Community posts"
    },
    "playground_pens/{penId}": {
      "description": "Shared code snippets for HTML/CSS/JS Playground"
    }
  }
}
